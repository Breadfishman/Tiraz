{
  "name": "tiraz",
  "version": "0.1.0",
  "description": "A design-taste engine for AI coding agents — breeds frontend variants and converges on the best via a fitness-gated beam search.",
  "type": "module",
  "bin": {
    "tiraz": "./dist/cli.js"
  },
  "keywords": [
    "design",
    "frontend",
    "ui",
    "ai",
    "claude",
    "claude-code",
    "design-system",
    "anti-slop",
    "beam-search",
    "cli"
  ],
  "homepage": "https://github.com/Breadfishman/Tiraz#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Breadfishman/Tiraz.git"
  },
  "bugs": {
    "url": "https://github.com/Breadfishman/Tiraz/issues"
  },
  "files": [
    "dist",
    "skills",
    "LICENSE",
    "NOTICE"
  ],
  "engines": {
    "node": ">=22"
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test:cov && npm run build && node dist/cli.js --version",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "optionalDependencies": {
    "playwright": "^1.60.0"
  }
}
